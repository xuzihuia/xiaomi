<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="设置"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/gold_primary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp" />

    <!-- 更新间隔 -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/updateIntervalLayout"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:hint="更新间隔（秒）"
        app:layout_constraintTop_toBottomOf="@id/titleText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/updateIntervalInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:text="60" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- 基准价格 -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/baselinePriceLayout"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:hint="基准价格（元）"
        app:layout_constraintTop_toBottomOf="@id/updateIntervalLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/baselinePriceInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:text="4500" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- 预警设置 -->
    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/alertSwitch"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="启用价格预警"
        android:checked="true"
        android:layout_margin="16dp"
        app:layout_constraintTop_toBottomOf="@id/baselinePriceLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <!-- 保存按钮 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/saveButton"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="保存设置"
        android:textSize="16sp"
        android:layout_margin="16dp"
        app:backgroundTint="@color/gold_primary"
        app:layout_constraintTop_toBottomOf="@id/alertSwitch"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
